<div class="min-h-screen pb-24" data-controller="meet-filter">
  <%# Header %>
  <div class="px-6 pt-10 pb-6 flex items-start justify-between">
    <div>
      <h1 class="font-extrabold tracking-tight text-3xl">Rencontres</h1>
      <p class="text-white/40 text-sm mt-1">Visualisez facilement vos prochaines rencontres et restez prêt pour chaque session.</p>
    </div>
    <button data-action="click->meet-filter#openModal"
      class="relative mt-2 flex items-center gap-2 px-4 py-2 rounded-full border border-white/15 bg-white/5 text-sm font-semibold text-white hover:bg-white/10 transition-colors">
      <i class="fa-solid fa-sliders text-base"></i>
      Filtrer
      <span data-meet-filter-target="filterBadge"
            class="hidden absolute -top-1 -right-1 w-4 h-4 rounded-full text-[9px] font-black flex items-center justify-center"
            style="background-color: var(--color-primary);">!</span>
    </button>
  </div>
  <%# ============================================================ %>
  <%# SECTION "EN COURS" — affichée uniquement si au moins un meet %>
  <%# est actif ou en attente d'action pour l'utilisateur courant. %>
  <%# data-controller="session-filter" active le filtrage Stimulus. %>
  <%# ============================================================ %>
  <% if @in_progress_meets.any? %>
    <section class="mt-4" data-meet-filter-target="section" data-controller="session-filter">
      <% in_progress_match_count   = @in_progress_meets.count { |m| m.meetable_type == "Match" } %>
      <% in_progress_program_count = @in_progress_meets.count { |m| m.meetable_type == "Program" } %>
      <div class="flex items-center justify-between px-6 mb-3">
        <h2 class="font-bold text-base">En cours</h2>
      </div>
      <% if in_progress_match_count > 0 && in_progress_program_count > 0 %>
        <div class="flex gap-2 px-6 mb-4">
          <button data-session-filter-target="btn" data-filter-type="all" data-action="click->session-filter#filter"
            class="text-xs font-bold px-3 py-1 rounded-full text-white bg-white/10 transition">Tous (<%= @in_progress_meets.count %>)</button>
          <button data-session-filter-target="btn" data-filter-type="Match" data-action="click->session-filter#filter"
            class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Match (<%= in_progress_match_count %>)</button>
          <button data-session-filter-target="btn" data-filter-type="Program" data-action="click->session-filter#filter"
            class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Entraînement (<%= in_progress_program_count %>)</button>
        </div>
      <% end %>
      <% solo = @in_progress_meets.count == 1 %>
      <div class="<%= solo ? 'px-6' : 'flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide' %>">
        <% @in_progress_meets.each do |meet| %>
          <%# Calcul du statut et des couleurs pour cette carte :
              - pending      : QR code généré, en attente de scan → jaune
              - waiting_score: durée écoulée, aucun score saisi   → rouge
              - live         : dans la fenêtre horaire active      → vert
              card_status est écrit dans data-type pour que le filtre Stimulus puisse cibler la carte. %>
          <% pending       = meet.meetable_type == "Match" && meet.meetable.pending_confirmation? %>
          <% waiting_score = meet.meetable_type == "Match" && meet.meetable.qr_code.nil? && (meet.date + meet.duration.minutes) <= Time.current %>
          <% live_color       = pending ? "#f59e0b" : "#22c55e" %>
          <% live_border      = pending ? "rgba(245,158,11,0.3)" : "rgba(34,197,94,0.3)" %>
          <% live_label_color = pending ? "rgba(251,191,36,0.8)" : "rgba(134,239,172,0.8)" %>
          <% card_status      = pending ? "pending" : waiting_score ? "waiting_score" : "live" %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <%# Carte match — data-type=card_status permet le filtrage par le session-filter controller
                data-meet-filter-target="card" est utilisé par le filtre global (proximité/date) %>
            <%= link_to meet_path(meet),
                  class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col",
                  style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);",
                  data: { "meet-filter-target": "card", "session-filter-target": "card",
                          type: "Match", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <%# Trait coloré en haut — couleur = statut du match %>
              <div class="h-1 w-full" style="background:linear-gradient(90deg,<%= live_color %>,<%= live_color %>88);"></div>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <%# Ligne statut + heure %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:<%= live_color %>;"></span>
                    <span class="text-xs font-black uppercase tracking-widest" style="color:<%= live_label_color %>;">
                      <%= pending ? "En attente de validation" : "En cours" %>
                    </span>
                  </div>
                </div>
                <%# Scores des équipes (nombre de joueurs) %>
                <div class="flex-1 flex items-center justify-center gap-2 py-3 px-3 rounded-2xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.blue_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Bleu</span>
                  </div>
                  <%= image_tag "vs.png", class: "w-12 h-12 object-contain mb-5" %>
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.red_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Rouge</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 truncate min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <%# Carte programme — toujours vert (aucun statut de validation possible)
                data-type="live" pour correspondre au filtre "En cours" %>
            <%= link_to meet_path(meet),
                  class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col",
                  style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);",
                  data: { "meet-filter-target": "card", "session-filter-target": "card",
                          type: "Program", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <%# Ligne statut + heure %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:<%= live_color %>;"></span>
                    <span class="text-xs font-black uppercase tracking-widest" style="color:<%= live_label_color %>;">En cours</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= meet.meetable.title %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= meet.meetable.level %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= meet.duration %> min</span>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
  <%# 1. Mes rencontres %>
  <section class="mt-4" data-meet-filter-target="section" data-controller="session-filter">
    <% my_match_count   = @my_meets.count { |m| m.meetable_type == "Match" } %>
    <% my_program_count = @my_meets.count { |m| m.meetable_type == "Program" } %>
    <div class="flex items-center justify-between px-6 mb-3">
      <h2 class="font-bold text-base">Mes Matchs & Entraînements à venir</h2>
    </div>
    <% if my_match_count > 0 && my_program_count > 0 %>
      <div class="flex gap-2 px-6 mb-4">
        <button data-session-filter-target="btn" data-filter-type="all" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white bg-white/10 transition">Tous (<%= @my_meets.count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Match" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Match (<%= my_match_count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Program" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Entraînement (<%= my_program_count %>)</button>
      </div>
    <% end %>
    <% if @my_meets.any? %>
      <% solo = @my_meets.count == 1 %>
      <div class="<%= solo ? 'px-6' : 'flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide' %>" data-cards-list>
        <% @my_meets.each do |meet| %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <% cancelled = match.cancelled? %>
            <% accent = cancelled ? "#ef4444" : "var(--color-primary)" %>
            <% border_color = cancelled ? "rgba(239,68,68,0.25)" : "rgba(255,255,255,0.08)" %>
            <%= link_to meet_path(meet), class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);", data: { "meet-filter-target": "card", "session-filter-target": "card", type: "Match", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <% if cancelled %>
                <div class="h-1 w-full" style="background:linear-gradient(90deg,#ef4444,#ef444488);"></div>
              <% end %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <% if cancelled %>
                      <i class="fa-solid fa-ban text-[10px] text-red-400/80"></i>
                      <span class="text-xs font-black uppercase tracking-widest text-red-400/80">Match annulé</span>
                    <% else %>
                      <i class="fa-solid fa-trophy text-[10px]" style="color:#fbbf24;"></i>
                      <span class="text-xs font-black uppercase tracking-widest" style="color:var(--color-primary);">Match à venir</span>
                    <% end %>
                  </div>
                </div>
                <div class="flex-1 flex items-center justify-center gap-2 py-3 px-3 rounded-2xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.blue_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Bleu</span>
                  </div>
                  <%= image_tag "vs.png", class: "w-12 h-12 object-contain mb-5" %>
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.red_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Rouge</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 truncate min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2" ><%= l(meet.date, format: "%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <%# Style entrainement %>
            <% accent = "#a855f7" %>
            <%= link_to meet_path(meet), class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);", data: { "meet-filter-target": "card", "session-filter-target": "card", type: "Program", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <i class="fa-solid fa-dumbbell text-[10px] text-purple-400/80"></i>
                    <span class="text-xs font-black uppercase tracking-widest text-purple-400/80">Entraînement</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= meet.meetable.title %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= meet.meetable.level %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= meet.duration %> min</span>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2" ><%= l(meet.date, format: "%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 p-6 rounded-2xl bg-white/5 border border-dashed border-white/10 flex flex-col items-center justify-center text-center">
        <p class="text-white/60 text-xs">Vous n'avez aucune rencontre prévue.</p>
      </div>
    <% end %>
  </section>
  <%# Bouton + flottant %>
  <div class="fixed bottom-24 right-4 z-50 dropdown dropdown-top dropdown-end group" style="padding-bottom: env(safe-area-inset-bottom);">
    <button tabindex="0" class="flex items-center justify-center w-14 h-14 rounded-full shadow-lg"
            style="background-color: var(--color-primary); box-shadow: 0 0 20px color-mix(in srgb, var(--color-primary) 50%, transparent);">
      <i class="fa-solid fa-plus text-white text-xl transition-transform duration-200 group-focus-within:rotate-45"></i>
    </button>
    <ul tabindex="0" class="dropdown-content menu bg-base-200 rounded-2xl shadow-xl p-2 mb-3 w-52 border border-white/10">
      <%= link_to new_match_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 transition-colors" do %>
        <i class="fa-solid fa-basketball text-primary w-4 text-center"></i>
        <span class="text-base font-medium">Créer un match</span>
      <% end %>
      <%= link_to new_program_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 transition-colors" do %>
        <i class="fa-solid fa-dumbbell text-secondary w-4 text-center"></i>
        <span class="text-base font-medium">Créer un entrainement</span>
      <% end %>
    </ul>
  </div>
  <%# 2. Rencontres à venir (Global) %>
  <section class="mt-8" data-meet-filter-target="section" data-controller="session-filter">
    <% upcoming_match_count   = @upcoming_meets.count { |m| m.meetable_type == "Match" } %>
    <% upcoming_program_count = @upcoming_meets.count { |m| m.meetable_type == "Program" } %>
    <div class="flex items-center justify-between px-6 mb-3">
      <h2 class="font-bold text-base">Les rencontres autour de vous</h2>
    </div>
    <% if upcoming_match_count > 0 && upcoming_program_count > 0 %>
      <div class="flex gap-2 px-6 mb-4">
        <button data-session-filter-target="btn" data-filter-type="all" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white bg-white/10 transition">Tous (<%= @upcoming_meets.count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Match" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Match (<%= upcoming_match_count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Program" data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Entraînement (<%= upcoming_program_count %>)</button>
      </div>
    <% end %>
    <% if @upcoming_meets.any? %>
      <% solo = @upcoming_meets.count == 1 %>
      <div class="<%= solo ? 'px-6' : 'flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide' %>" data-meet-filter-target="list" data-cards-list>
        <% @upcoming_meets.each do |meet| %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <% cancelled = match.cancelled? %>
            <% accent = cancelled ? "#ef4444" : "var(--color-primary)" %>
            <% border_color = cancelled ? "rgba(239,68,68,0.25)" : "rgba(255,255,255,0.08)" %>
            <%= link_to meet_path(meet), class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);", data: { "meet-filter-target": "card", "session-filter-target": "card", type: "Match", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <% if cancelled %>
                <div class="h-1 w-full" style="background:linear-gradient(90deg,#ef4444,#ef444488);"></div>
              <% end %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <% if cancelled %>
                      <i class="fa-solid fa-ban text-[10px] text-red-400/80"></i>
                      <span class="text-xs font-black uppercase tracking-widest text-red-400/80">Match annulé</span>
                    <% else %>
                      <i class="fa-solid fa-trophy text-[10px]" style="color:#fbbf24;"></i>
                      <span class="text-xs font-black uppercase tracking-widest" style="color:var(--color-primary);">Match à venir</span>
                    <% end %>
                  </div>
                </div>
                <div class="flex items-center justify-center gap-2 py-3 px-3 rounded-2xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.blue_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Bleu</span>
                  </div>
                  <%= image_tag "vs.png", class: "w-12 h-12 object-contain mb-5" %>
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.red_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Rouge</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 truncate min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <% accent = "#a855f7" %>
            <%= link_to meet_path(meet), class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);", data: { "meet-filter-target": "card", "session-filter-target": "card", type: "Program", lat: meet.court.lat, lng: meet.court.long, date: meet.date.to_i } do %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <i class="fa-solid fa-dumbbell text-[10px] text-purple-400/80"></i>
                    <span class="text-xs font-black uppercase tracking-widest text-purple-400/80">Entraînement</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= meet.meetable.title %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= meet.meetable.level %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= meet.duration %> min</span>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </section>
  <%# 3. Mes programmes d'entraînement %>
  <section class="mt-8" data-meet-filter-target="section">
    <div class="flex items-center justify-between px-6 mb-4">
      <h2 class="font-bold text-base">Mes programmes d'entraînement</h2>
    </div>
    <% if @programs.any? %>
      <div class="flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide" data-cards-list>
        <% @programs.each do |program| %>
          <% next_meet = program.meets.select { |m| m.date >= Time.current }.min_by(&:date) %>
          <%= link_to program_path(program), class: "flex-shrink-0 w-76 rounded-2xl border overflow-hidden flex flex-col", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);", data: { "meet-filter-target": "card", lat: next_meet&.court&.lat, lng: next_meet&.court&.long, date: next_meet&.date&.to_i } do %>
            <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <i class="fa-solid fa-dumbbell text-[10px] text-purple-400/80"></i>
                  <span class="text-xs font-black uppercase tracking-widest text-purple-400/80">Entraînement</span>
                </div>
              </div>
              <div class="flex flex-col gap-2 py-2">
                <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= program.title %></span>
                <div class="flex flex-col gap-1">
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= program.level %></span>
                  <% if next_meet %>
                    <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= next_meet.duration %> min</span>
                  <% end %>
                  <% upcoming_meets = program.meets.select { |m| m.date >= Time.current }.sort_by(&:date) %>
                  <% if upcoming_meets.any? %>
                    <% if upcoming_meets.count == 1 %>
                      <span class="text-[14px] font-normal text-white inline-flex items-center gap-1.5"><i class="fa-regular fa-calendar-days text-[12px]"></i> Prochaine séance : <%= upcoming_meets.first.date.strftime("%-d %b · %H:%M") %></span>
                    <% else %>
                      <span class="text-[14px] font-normal text-white inline-flex items-center gap-1.5"><i class="fa-regular fa-calendar-days text-[12px]"></i> Prochaines séances :</span>
                      <% upcoming_meets.each do |m| %>
                        <span class="text-[14px] font-normal text-white pl-4">· <%= m.date.strftime("%-d %b · %H:%M") %></span>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(168,85,247,0.2);"><i class="fa-solid fa-robot text-[8px] text-purple-400"></i></div>
                  <span class="text-[14px] text-white/60 font-medium">Modèle IA</span>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 p-8 rounded-3xl bg-white/[0.02] border border-dashed border-white/10 flex flex-col items-center justify-center text-center">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mb-4"><i class="fa-solid fa-dumbbell text-white/20 text-xl"></i></div>
        <p class="text-white/40 text-sm font-medium">Aucun entraînement</p>
        <%= link_to "Créer maintenant", new_program_path, class: "mt-4 px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-wider text-white", style: "background-color: var(--color-secondary);" %>
      </div>
    <% end %>
  </section>
  <%# Modal filtres %>
  <dialog data-meet-filter-target="modal" class="modal modal-bottom">
    <div class="modal-box rounded-t-3xl rounded-b-none pb-10">
      <div class="flex items-center justify-between mb-6">
        <h3 class="font-extrabold text-lg">Filtrer</h3>
        <button data-action="click->meet-filter#resetFilters" class="text-xs text-white/40 hover:text-white/70">Réinitialiser</button>
      </div>
      <div class="mb-6">
        <p class="text-xs text-white/40 uppercase tracking-widest font-bold mb-3">Trier par</p>
        <div class="flex gap-2 flex-wrap">
          <button data-action="click->meet-filter#selectSort" data-meet-filter-target="sortBtn" data-sort="date" class="btn btn-sm rounded-full btn-primary">Date</button>
          <button data-action="click->meet-filter#selectSort" data-meet-filter-target="sortBtn" data-sort="proximity" class="btn btn-sm rounded-full btn-ghost">Proximité</button>
        </div>
      </div>
      <div class="mb-8">
        <p class="text-xs text-white/40 uppercase tracking-widest font-bold mb-3">Distance max</p>
        <div class="flex gap-2 flex-wrap">
          <% [0, 500, 1000, 5000, 10000].each do |r| %>
            <button data-action="click->meet-filter#selectRadius" data-meet-filter-target="radiusBtn" data-radius="<%= r %>" class="btn btn-sm rounded-full <%= r == 0 ? 'btn-primary' : 'btn-ghost' %>">
              <%= r == 0 ? 'Toutes' : (r < 1000 ? "#{r}m" : "#{r/1000}km") %>
            </button>
          <% end %>
        </div>
      </div>
      <button data-action="click->meet-filter#applyFilters" class="btn w-full rounded-full font-bold text-white" style="background-color: var(--color-primary);">Appliquer</button>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</div>
