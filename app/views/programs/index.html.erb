<div class="min-h-screen pb-24">

  <%# Header %>
  <div class="px-6 pt-10 pb-6 flex items-start justify-between">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight">Rencontres</h1>
      <p class="text-white/40 text-base mt-2 max-w-xs">Retrouvez vos matchs et vos entraînements à venir et passés et créez vos propres entraînements grâce à l'IA</p>
    </div>
    <%= link_to new_program_path, class: "flex items-center justify-center w-10 h-10 rounded-full flex-shrink-0 mt-1", style: "background-color: var(--color-primary);" do %>
      <i class="fa-solid fa-plus text-white text-base"></i>
    <% end %>
  </div>

</div>
