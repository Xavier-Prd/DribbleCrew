<div>
  <h1 class="font-bold text-4xl">Programs#new</h1>
  <p>Find me in app/views/programs/new.html.erb</p>
</div>
<%= simple_form_for @program do |f| %>
  <div class="form-control md:col-span-2">
    <%= f.label :goal, "Goal", class: "label" %>
    <%= f.text_area :goal, rows: 3, class: "textarea textarea-bordered w-full",
          placeholder: "Exemple: Améliorer mes sauts et ma vitesse." %>
  </div>
  <div class="form-control">
    <%= f.label :level, "Level", class: "label" %>
    <div class="join w-full">
      <span class="join-item btn btn-ghost pointer-events-none">
        <i class="fa-solid fa-layer-group"></i>
      </span>
      <%= f.select :level, Program::LEVELS, {}, class: "join-item select select-bordered w-full" %>
    </div>
  </div>
  <%= f.submit "Créer un programme" %>
<% end %>
