<div class="min-h-screen pb-24">

  <%# Header %>
  <div class="px-6 pt-10 pb-6">
    <%= link_to profile_path(@user), class: "flex items-center gap-2 text-white/40 text-base mb-4" do %>
      <i class="fa-solid fa-chevron-left text-base"></i> Retour
    <% end %>
    <h1 class="font-extrabold tracking-tight">Rencontres</h1>
    <p class="text-white/40 text-base mt-2">Toutes les sessions passées de <span class="text-white font-semibold"><%= @user.username %></span>.</p>
  </div>

  <%# Filtre les rencontres passées auxquelles l'utilisateur a participé :
      - Programme : l'utilisateur fait partie de l'équipe du programme
      - Match     : l'utilisateur est dans l'équipe bleue ou rouge %>
  <% past_meets = @meets.select { |meet|
      (meet.meetable_type == "Program" && meet.meetable.team.users.include?(@user)) ||
      (meet.meetable_type == "Match"   && (meet.meetable.red_team.users.include?(@user) || meet.meetable.blue_team.users.include?(@user)))
    } %>

  <% if past_meets.any? %>

    <%# Section filtrée par le controller Stimulus session-filter.
        data-controller active le controller sur ce conteneur. %>
    <div data-controller="session-filter">

      <%# Boutons de filtre — chaque bouton a :
          - data-session-filter-target="btn"  : référencé par le controller pour gérer le style actif/inactif
          - data-filter-type                  : valeur transmise au controller ("all", "Match", "Program")
          - data-action                       : déclenche session_filter#filter au clic
          Le bouton "Tous" est actif par défaut (classes text-white + bg-white/10). %>
      <div class="flex gap-2 px-6 mb-4">
        <button data-session-filter-target="btn" data-filter-type="all"
                data-action="click->session-filter#filter"
                class="text-xs font-bold px-3 py-1 rounded-full text-white bg-white/10 transition">Tous</button>
        <button data-session-filter-target="btn" data-filter-type="Match"
                data-action="click->session-filter#filter"
                class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Match</button>
        <button data-session-filter-target="btn" data-filter-type="Program"
                data-action="click->session-filter#filter"
                class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Programme</button>
      </div>

      <div class="flex flex-col gap-3 px-6">
        <% past_meets.each do |meet| %>

          <%# Calcul des variables d'affichage selon le type de rencontre %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <% blue_s = match.blue_team_score.to_i; red_s = match.red_team_score.to_i %>
            <%# true si l'utilisateur est dans l'équipe bleue %>
            <% user_on_blue = match.blue_team.users.include?(@user) %>
            <%# Résultat du point de vue de l'utilisateur %>
            <% user_won  = user_on_blue ? blue_s > red_s : red_s > blue_s %>
            <% user_lost = user_on_blue ? red_s > blue_s : blue_s > red_s %>
            <% accent       = user_won ? "#22c55e" : user_lost ? "#ef4444" : "#6b7280" %>
            <% result_label = user_won ? "Victoire" : user_lost ? "Défaite" : "Égalité" %>
            <%# Score dominant affiché en blanc vif, score perdant en blanc estompé %>
            <% blue_score_color = blue_s >= red_s ? "rgba(255,255,255,0.95)" : "rgba(255,255,255,0.25)" %>
            <% red_score_color  = red_s >= blue_s ? "rgba(255,255,255,0.95)" : "rgba(255,255,255,0.25)" %>
            <%# Fond coloré pour la bulle du gagnant, neutre pour le perdant %>
            <% blue_circle_bg = blue_s > red_s ? "rgba(59,130,246,0.25)" : "rgba(255,255,255,0.04)" %>
            <% red_circle_bg  = red_s > blue_s ? "rgba(239,68,68,0.25)"  : "rgba(255,255,255,0.04)" %>
          <% else %>
            <% accent = "#a855f7" %>
          <% end %>

          <%# data-session-filter-target="card" : référencé par le controller pour afficher/cacher la carte
              data-type                         : correspond à meetable_type ("Match" ou "Program"),
                                                  utilisé par le controller pour filtrer %>
          <%= link_to meet_path(meet),
                class: "flex items-center gap-4 rounded-2xl border border-white/8 overflow-hidden bg-white/5",
                data: { session_filter_target: "card", type: meet.meetable_type } do %>
            <%# Trait coloré à gauche — couleur selon résultat (vert/rouge/gris) ou violet pour programme %>
            <div class="w-1 self-stretch flex-shrink-0" style="background:<%= accent %>;"></div>

            <%# Contenu %>
            <div class="flex items-center gap-4 flex-1 min-w-0 py-4 pr-4">

              <% if meet.meetable_type == "Match" %>
                <%# Cercles scores %>
                <div class="flex items-center gap-1.5 flex-shrink-0">

                  <%# Bulle équipe bleue %>
                  <div class="flex flex-col items-center gap-0.5">
                    <%# mb-3 sur les deux bulles pour qu'elles restent à la même hauteur %>
                    <div class="relative w-11 h-11 rounded-full flex items-center justify-center border border-white/10 mb-3" style="background:<%= blue_circle_bg %>;">
                      <span class="text-base font-black tabular-nums" style="color:<%= blue_score_color %>;"><%= match.blue_team_score %></span>
                      <%# Photo positionnée à moitié dans la bulle, à moitié en dessous %>
                      <% if user_on_blue %>
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-5 h-5 rounded-full overflow-hidden border border-white/20">
                          <% if @user.profile_picture.attached? %>
                            <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                          <% else %>
                            <div class="w-full h-full bg-base-300 flex items-center justify-center">
                              <i class="fa-solid fa-user text-[5px] text-white/40"></i>
                            </div>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                    <span class="text-[8px] font-semibold uppercase tracking-wider text-white/25">Bleu</span>
                  </div>

                  <%= image_tag "vs.png", class: "w-7 h-7 object-contain mb-3" %>

                  <%# Bulle équipe rouge %>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="relative w-11 h-11 rounded-full flex items-center justify-center border border-white/10 mb-3" style="background:<%= red_circle_bg %>;">
                      <span class="text-base font-black tabular-nums" style="color:<%= red_score_color %>;"><%= match.red_team_score %></span>
                      <%# Photo positionnée à moitié dans la bulle, à moitié en dessous %>
                      <% unless user_on_blue %>
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-5 h-5 rounded-full overflow-hidden border border-white/20">
                          <% if @user.profile_picture.attached? %>
                            <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                          <% else %>
                            <div class="w-full h-full bg-base-300 flex items-center justify-center">
                              <i class="fa-solid fa-user text-[5px] text-white/40"></i>
                            </div>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                    <span class="text-[8px] font-semibold uppercase tracking-wider text-white/25">Rouge</span>
                  </div>

                </div>

                <%# Infos texte du match %>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-white"><%= result_label %></p>
                  <p class="text-xs text-white/40 truncate mt-0.5"><%= meet.court&.name || "Terrain inconnu" %></p>
                  <p class="text-xs text-white/25 mt-0.5"><%= meet.date.strftime("%-d %b %Y") %> · <%= meet.duration %> min</p>
                </div>

              <% else %>
                <%# Rond icône pour les programmes d'entraînement %>
                <div class="w-11 h-11 rounded-full flex items-center justify-center border border-white/10 flex-shrink-0" style="background:rgba(168,85,247,0.2);">
                  <i class="fa-solid fa-dumbbell text-white/60 text-base"></i>
                </div>

                <%# Infos texte du programme %>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-white truncate"><%= meet.meetable.title %></p>
                  <p class="text-xs text-white/40 truncate mt-0.5"><%= meet.court&.name || "Terrain inconnu" %></p>
                  <p class="text-xs text-white/25 mt-0.5"><%= meet.date.strftime("%-d %b %Y") %> · <%= meet.duration %> min</p>
                </div>

              </div>

              <%# Infos %>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-white"><%= result_label %></p>
                <p class="text-xs text-white/40 truncate mt-0.5"><%= meet.court&.name || "Terrain inconnu" %></p>
                <p class="text-xs text-white/25 mt-0.5"><%= l(meet.date, format: "%-d %b %Y") %> · <%= meet.duration %> min</p>
              </div>

            <% else %>
              <%# Rond programme %>
              <div class="w-11 h-11 rounded-full flex items-center justify-center border border-white/10 flex-shrink-0" style="background:rgba(168,85,247,0.2);">
                <i class="fa-solid fa-dumbbell text-white/60 text-base"></i>
              </div>

              <%# Infos %>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-white truncate"><%= meet.meetable.title %></p>
                <p class="text-xs text-white/40 truncate mt-0.5"><%= meet.court&.name || "Terrain inconnu" %></p>
                <p class="text-xs text-white/25 mt-0.5"><%= l(meet.date, format: "%-d %b %Y") %> · <%= meet.duration %> min</p>
              </div>

              <%# Niveau %>
              <span class="flex-shrink-0 text-[10px] font-semibold text-white/40"><%= meet.meetable.level %></span>
            <% end %>

          </div>
        <% end %>
      </div>

    </div>

  <% else %>
    <div class="mx-6 h-40 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
      <p class="text-white/30 text-base">Aucune rencontre passée.</p>
    </div>
  <% end %>

</div>
