<div class="min-h-screen pb-24" data-controller="toggle">
  <%# Header %>
  <%# Le menu engrenage (modifier profil + déconnexion) n'est affiché
      que si l'utilisateur connecté consulte son propre profil.
      Sur le profil d'un autre utilisateur, ce bloc est masqué. %>
  <% if current_user == @user %>
    <div class="px-4 pt-4 pb-2 flex items-start justify-end">
      <div class="relative flex-shrink-0 mt-1">
        <%# Bouton d'ouverture du menu — le controller Stimulus "toggle" gère l'affichage %>
        <button type="button" data-action="toggle#toggle" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/5">
          <i class="fa-solid fa-gear text-xl text-white/70 transition-transform duration-300" data-toggle-target="gear"></i>
        </button>
        <%# Menu déroulant avec les actions propres au profil connecté %>
        <div data-toggle-target="form" class="hidden absolute right-0 top-12 z-10 min-w-48 rounded-xl bg-base-200 border border-white/10 overflow-hidden">
          <%= link_to edit_profile_path(@user), class: "flex items-center gap-2 px-4 py-2.5 text-base font-medium hover:bg-base-300 transition-colors" do %>
            <i class="fa-solid fa-pen-to-square text-primary"></i> Modifier mon profil
          <% end %>
          <div class="border-t border-white/10"></div>
          <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-2 px-4 py-2.5 text-base font-medium text-error hover:bg-base-300 transition-colors w-full text-left" do %>
            <i class="fa-solid fa-right-from-bracket"></i> Se déconnecter
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <%# Espace réservé pour conserver le même écart en haut que sur son propre profil %>
    <div class="pt-4 pb-2 h-14"></div>
  <% end %>
  <%# Avatar + nom + stats %>
  <div class="flex items-center gap-5 px-6 pb-6">
    <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-white/10 flex-shrink-0">
      <% if @user.profile_picture.attached? %>
        <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
      <% else %>
        <div class="w-full h-full bg-base-300 flex items-center justify-center">
          <i class="fa-solid fa-user text-4xl text-white/60"></i>
        </div>
      <% end %>
    </div>
    <div class="flex flex-col gap-3 min-w-0">
      <h1 class="font-extrabold tracking-tight truncate"><%= @user.username %></h1>
      <%# Compteurs stats %>
      <div class="flex items-center gap-5">
        <div class="flex flex-col gap-0.5">
          <span class="text-2xl font-black text-primary"><%= @total_points.round %></span>
          <span class="text-xs text-white/40">pts total</span>
        </div>
        <div class="w-px h-8 bg-white/10"></div>
        <div class="flex flex-col gap-0.5">
          <span class="text-2xl font-black text-white"><%= @won_matches %></span>
          <span class="text-xs text-white/40">matchs gagnés</span>
        </div>
      </div>
    </div>
  </div>
  <%# Classements %>
  <section class="mt-4">
    <div class="flex items-center justify-between px-6 mb-4">
      <h2 class="font-bold">Classement</h2>
      <%= link_to "Voir plus", classements_profile_path(@user), class: "text-base text-white/40" %>
    </div>
    <% if @classements.any? %>
      <div class="flex gap-4 overflow-x-auto px-6 pb-6 scrollbar-hide">
        <% @classements.first(10).each do |classement| %>
          <% card_border_image = case classement[:rank]
                                  when 1 then "avatar_border_king.png"
                                  when 2 then "avatar_border_second.png"
                                  when 3 then "avatar_border_third.png"
                                  else        "avatar_border_default.png"
                                  end %>
          <%= link_to court_path(classement[:court]), class: "flex-shrink-0 w-80 rounded-2xl overflow-hidden flex flex-col border border-white/10 bg-white/5", style: "box-shadow:0 4px 24px rgba(0,0,0,0.4);" do %>
            <%# Image terrain %>
            <div class="relative h-30 w-full">
              <% if classement[:court].image.attached? %>
                <%= image_tag classement[:court].image, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full bg-base-200 flex items-center justify-center">
                  <i class="fa-solid fa-basketball text-3xl text-white/20"></i>
                </div>
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-base-300/80 to-transparent"></div>
              <%# Avatar + bordure PNG centré en bas de l'image %>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2">
                <div class="relative w-11 h-11">
                  <div class="w-full h-full rounded-full overflow-hidden">
                    <% if @user.profile_picture.attached? %>
                      <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center">
                        <i class="fa-solid fa-user text-white/60 text-xl"></i>
                      </div>
                    <% end %>
                  </div>
                  <%= image_tag card_border_image, class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
                </div>
              </div>
            </div>
            <%# Infos — pt-10 pour laisser la place à l'avatar qui déborde %>
            <div class="px-4 pt-10 pb-3 flex flex-col gap-1 items-center">
              <p class="text-base font-bold truncate"><%= classement[:court].name %></p>
              <p class="text-base font-semibold text-primary"><%= classement[:points].round %> pts</p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 h-24 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
        <p class="text-white/60 text-base">Aucune victoire pour l'instant.</p>
      </div>
    <% end %>
  </section>
  <%# Rencontres passées %>
  <section class="mt-8" data-controller="session-filter">
    <div class="flex items-center justify-between px-6 mb-3">
      <h2 class="font-bold">Rencontres passées</h2>
      <%= link_to "Voir plus", sessions_profile_path(@user) , class:"text-base text-white/40" %>
    </div>
    <%# @past_meets est déjà filtré en SQL dans le contrôleur — pas besoin de refiltrer ici %>
    <% past_match_count   = @past_meets.count { |meet| meet.meetable_type == "Match" } %>
    <% past_program_count = @past_meets.count { |meet| meet.meetable_type == "Program" } %>
    <% if past_match_count > 0 && past_program_count > 0 %>
      <div class="flex gap-2 px-6 mb-4">
        <button data-session-filter-target="btn" data-filter-type="all"
                data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white bg-white/10 transition">Tous (<%= @past_meets.count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Match"
                data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Match (<%= past_match_count %>)</button>
        <button data-session-filter-target="btn" data-filter-type="Program"
                data-action="click->session-filter#filter"
          class="text-xs font-bold px-3 py-1 rounded-full text-white/40 bg-transparent transition">Entraînement (<%= past_program_count %>)</button>
      </div>
    <% end %>
    <% if @past_meets.any? %>
      <% solo = @past_meets.first(10).count == 1 %>
      <div class="<%= solo ? 'px-6' : 'flex gap-4 overflow-x-auto px-6 pb-6 scrollbar-hide' %>">
        <% @past_meets.first(10).each do |meet| %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <% blue_s = match.blue_team_score.to_i; red_s = match.red_team_score.to_i %>
            <%# On compare les IDs directement — pas besoin de charger match.blue_team.users %>
            <% user_on_blue = @user_team_ids.include?(match.blue_team_id) %>
            <% user_won  = user_on_blue ? blue_s > red_s : red_s > blue_s %>
            <% user_lost = user_on_blue ? red_s > blue_s : blue_s > red_s %>
            <% accent       = user_won ? "#22c55e" : user_lost ? "#ef4444" : "#6b7280" %>
            <% result_label = user_won ? "Victoire" : user_lost ? "Défaite" : "Égalité" %>
            <% result_color = user_won ? "#86efac" : user_lost ? "#fca5a5" : "rgba(255,255,255,0.4)" %>
            <% result_icon  = user_won ? "fa-trophy" : user_lost ? "fa-circle-xmark" : "fa-handshake" %>
            <% icon_color   = user_won ? "#fbbf24" : user_lost ? "#fca5a5" : "rgba(255,255,255,0.3)" %>
            <% blue_score_color = blue_s >= red_s ? "rgba(255,255,255,0.95)" : "rgba(255,255,255,0.25)" %>
            <% red_score_color  = red_s >= blue_s ? "rgba(255,255,255,0.95)" : "rgba(255,255,255,0.25)" %>
            <% blue_circle = blue_s > red_s ? "background:radial-gradient(circle at 35% 35%,rgba(96,165,250,0.35),rgba(59,130,246,0.1));border:1.5px solid rgba(96,165,250,0.7);box-shadow:0 0 16px rgba(59,130,246,0.4);"
                                            : "background:rgba(255,255,255,0.04);border:1.5px solid rgba(255,255,255,0.1);" %>
            <% red_circle = red_s > blue_s ? "background:radial-gradient(circle at 35% 35%,rgba(248,113,113,0.35),rgba(239,68,68,0.1));border:1.5px solid rgba(248,113,113,0.7);box-shadow:0 0 16px rgba(239,68,68,0.4);"
                                           : "background:rgba(255,255,255,0.04);border:1.5px solid rgba(255,255,255,0.1);" %>
            <%= link_to meet_path(meet),
                  class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col",
                  style: "background:rgba(15,23,42,0.85);border-color:rgba(255,255,255,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.4);",
                  data: { session_filter_target: "card", type: meet.meetable_type } do %>
              <div class="h-1 w-full" style="background:linear-gradient(90deg,<%= accent %>,<%= accent %>88);"></div>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center gap-1.5">
                  <i class="fa-solid <%= result_icon %> text-xs" style="color:<%= icon_color %>;"></i>
                  <span class="text-xs font-black uppercase tracking-widest" style="color:<%= result_color %>;"><%= result_label %></span>
                </div>
                <div class="flex-1 flex items-center justify-center gap-2 py-3 px-3 rounded-2xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                  <div class="flex flex-col items-center gap-1.5">
                    <div class="relative w-16 h-16 rounded-full flex items-center justify-center mb-3" style="<%= blue_circle %>">
                      <span class="text-2xl font-black tabular-nums leading-none" style="color:<%= blue_score_color %>;"><%= match.blue_team_score %></span>
                      <% if user_on_blue %>
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-7 h-7 rounded-full overflow-hidden border-2 border-white/20">
                          <% if @user.profile_picture.attached? %>
                            <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                          <% else %>
                            <div class="w-full h-full bg-base-300 flex items-center justify-center">
                              <i class="fa-solid fa-user text-[8px] text-white/40"></i>
                            </div>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                    <span class="text-[9px] font-bold uppercase tracking-widest" style="color:<%= blue_s > red_s ? 'rgba(96,165,250,0.7)' : 'rgba(255,255,255,0.2)' %>;">Bleu</span>
                  </div>
                  <%= image_tag "vs.png", class: "w-12 h-12 object-contain mb-5" %>
                  <div class="flex flex-col items-center gap-1.5">
                    <div class="relative w-16 h-16 rounded-full flex items-center justify-center mb-3" style="<%= red_circle %>">
                      <span class="text-2xl font-black tabular-nums leading-none" style="color:<%= red_score_color %>;"><%= match.red_team_score %></span>
                      <% unless user_on_blue %>
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-7 h-7 rounded-full overflow-hidden border-2 border-white/20">
                          <% if @user.profile_picture.attached? %>
                            <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                          <% else %>
                            <div class="w-full h-full bg-base-300 flex items-center justify-center">
                              <i class="fa-solid fa-user text-[8px] text-white/40"></i>
                            </div>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                    <span class="text-[9px] font-bold uppercase tracking-widest" style="color:<%= red_s > blue_s ? 'rgba(248,113,113,0.7)' : 'rgba(255,255,255,0.2)' %>;">Rouge</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot flex-shrink-0 text-[12px]"></i>
                    <span class="truncate"><%= meet.court&.name || "Terrain inconnu" %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white flex-shrink-0 ml-2"><%= l(meet.date, format: "%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <%= link_to meet_path(meet),
                  class: "#{solo ? 'w-full' : 'flex-shrink-0 w-76'} rounded-2xl border overflow-hidden flex flex-col",
                  style: "background:rgba(15,23,42,0.85);border-color:rgba(255,255,255,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.4);",
                  data: { session_filter_target: "card", type: meet.meetable_type } do %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center gap-1.5">
                  <i class="fa-solid fa-dumbbell text-[10px] text-purple-400/80"></i>
                  <span class="text-xs font-black uppercase tracking-widest text-purple-400/80">Entraînement</span>
                </div>
                <div class="flex flex-col gap-2">
                  <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= meet.meetable.title %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= meet.meetable.level %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= meet.duration %> min</span>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot flex-shrink-0 text-[12px]"></i>
                    <span class="truncate"><%= meet.court&.name || "Terrain inconnu" %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white flex-shrink-0 ml-2"><%= l(meet.date, format: "%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 h-32 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
        <p class="text-white/60 text-base">Aucune rencontre passée</p>
      </div>
    <% end %>
  </section>
</div>
