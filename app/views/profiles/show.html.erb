<div class="min-h-screen pb-24" data-controller="toggle">

  <%# Header %>
  <%# Menu engrenage %>
  <div class="px-4 pt-4 pb-2 flex items-start justify-end">
    <div class="relative flex-shrink-0 mt-1 ">
      <button type="button" data-action="toggle#toggle" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/5">
        <i class="fa-solid fa-gear text-xl text-white/70 transition-transform duration-300" data-toggle-target="gear"></i>
      </button>
      <div data-toggle-target="form" class="hidden absolute right-0 top-12 z-10 min-w-48 rounded-xl bg-base-200 border border-white/10 overflow-hidden">
        <%= link_to edit_profile_path(@user), class: "flex items-center gap-2 px-4 py-2.5 text-base font-medium hover:bg-base-300 transition-colors" do %>
          <i class="fa-solid fa-pen-to-square text-primary"></i> Modifier mon profil
        <% end %>
        <div class="border-t border-white/10"></div>
        <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-2 px-4 py-2.5 text-base font-medium text-error hover:bg-base-300 transition-colors w-full text-left" do %>
          <i class="fa-solid fa-right-from-bracket"></i> Se déconnecter
        <% end %>
      </div>
    </div>
  </div>

  <%# Avatar %>
  <div class="flex flex-col items-center gap-3 pb-6">
    <div class="w-28 h-28 rounded-full overflow-hidden border-2 border-white/10">
      <% if @user.profile_picture.attached? %>
        <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
      <% else %>
        <div class="w-full h-full bg-base-300 flex items-center justify-center">
          <i class="fa-solid fa-user text-4xl text-white/30"></i>
        </div>
      <% end %>
    </div>
    <h1 class="text-4xl font-extrabold tracking-tight"><%= @user.username %></h1>

    <%# Compteurs stats %>
    <div class="flex items-center justify-center gap-6 mt-4">
      <div class="flex flex-col items-center gap-0.5">
        <span class="text-2xl font-black text-primary"><%= @total_points %></span>
        <span class="text-base text-white/40">pts total</span>
      </div>
      <div class="w-px h-8 bg-white/10"></div>
      <div class="flex flex-col items-center gap-0.5">
        <span class="text-2xl font-black text-white"><%= @won_matches %></span>
        <span class="text-base text-white/40">matchs gagnés</span>
      </div>
    </div>
  </div>

  <%# Classements %>
  <section class="mt-4">
    <div class="flex items-center justify-between px-6 mb-4">
      <h2 class="font-bold text-lg">Classement</h2>
      <%= link_to "Voir plus", classements_profile_path(@user), class: "text-base text-white/40" %>
    </div>
    <% if @classements.any? %>
      <div class="flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide">
        <% @classements.each do |classement| %>
          <% card_border_image = case classement[:rank]
                                  when 1 then "avatar_border_king.png"
                                  when 2 then "avatar_border_second.png"
                                  when 3 then "avatar_border_third.png"
                                  else        "avatar_border_default.png"
                                  end %>
          <%= link_to court_path(classement[:court]), class: "flex-shrink-0 w-80 rounded-2xl overflow-hidden flex flex-col border border-white/10 bg-white/5" do %>
            <%# Image terrain %>
            <div class="relative h-30 w-full">
              <% if classement[:court].image.attached? %>
                <%= image_tag classement[:court].image, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full bg-base-200 flex items-center justify-center">
                  <i class="fa-solid fa-basketball text-3xl text-white/20"></i>
                </div>
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-base-300/80 to-transparent"></div>
              <%# Avatar + bordure PNG centré en bas de l'image %>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2">
                <div class="relative w-11 h-11">
                  <div class="w-full h-full rounded-full overflow-hidden">
                    <% if @user.profile_picture.attached? %>
                      <%= image_tag @user.profile_picture, class: "w-full h-full object-cover" %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center">
                        <i class="fa-solid fa-user text-white/30 text-xl"></i>
                      </div>
                    <% end %>
                  </div>
                  <%= image_tag card_border_image, class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
                </div>
              </div>
            </div>
            <%# Infos — pt-10 pour laisser la place à l'avatar qui déborde %>
            <div class="px-4 pt-10 pb-3 flex flex-col gap-1 items-center">
              <p class="text-base font-bold truncate"><%= classement[:court].name %></p>
              <p class="text-base font-semibold text-primary"><%= classement[:victories] %> point<%= classement[:victories] > 1 ? "s" : "" %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 h-24 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
        <p class="text-white/30 text-base">Aucune victoire pour l'instant.</p>
      </div>
    <% end %>
  </section>

  <%# Rencontres passées %>
  <section class="mt-8">
    <div class="flex items-center justify-between px-6 mb-4">
      <h2 class="font-bold text-lg">Rencontres passées</h2>
      <span class="text-base text-white/40">Voir plus</span>
    </div>
    <% match_meets = @meets.select { |meet| meet.meetable_type == "Match" && (meet.meetable.red_team.users.include?(@user) || meet.meetable.blue_team.users.include?(@user)) } %>
    <% if match_meets.any? %>
      <div class="flex gap-4 overflow-x-auto px-6 pb-2 scrollbar-hide">
        <% match_meets.each do |meet| %>
          <% blue_s = meet.meetable.blue_team_score.to_i; red_s = meet.meetable.red_team_score.to_i %>
          <% grad_color = blue_s > red_s ? "rgba(59,130,246,0.18)" : red_s > blue_s ? "rgba(239,68,68,0.18)" : "rgba(255,255,255,0.06)" %>
          <%= link_to meet_path(meet), class: "flex-shrink-0 w-64 rounded-2xl border border-white/10 p-3 flex flex-col gap-3 relative overflow-hidden", style: "background: linear-gradient(135deg, #{grad_color}, transparent);" do %>
            <div class="flex items-center justify-between">
              <span class="badge badge-sm font-bold px-2 text-white tracking-wide" style="background-color: var(--color-primary);">MATCH</span>
              <span class="text-base font-bold text-white/40 tabular-nums"><%= meet.meetable.blue_team_score %> – <%= meet.meetable.red_team_score %></span>
            </div>
            <div class="flex items-center gap-1.5">
              <% if blue_s == red_s %>
                <i class="fa-solid fa-handshake text-white/40 text-base"></i>
                <span class="text-base font-semibold text-white/50">Égalité</span>
              <% else %>
                <i class="fa-solid fa-trophy text-base" style="color: #FFD700;"></i>
                <span class="text-base font-semibold"><%= blue_s > red_s ? "Équipe Bleue" : "Équipe Rouge" %></span>
              <% end %>
            </div>
            <div class="flex items-center justify-between text-base text-white/40">
              <div class="flex items-center gap-1">
                <i class="fa-regular fa-calendar"></i>
                <span><%= meet.date.strftime("%d %b %Y") %></span>
              </div>
              <div class="flex items-center gap-1">
                <i class="fa-regular fa-clock"></i>
                <span><%= meet.duration %> min</span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="mx-6 h-32 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
        <p class="text-white/30 text-base">Aucune rencontre passée</p>
      </div>
    <% end %>
  </section>

</div>
