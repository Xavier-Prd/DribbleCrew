<div class="container mx-auto">
  <h1 class="text-2xl font-bold">Mon profil</h1>

  <!-- USERNAME -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Username :</strong> <%= @user.username %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :username, label: false %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>

  <!-- EMAIL -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Email :</strong> <%= @user.email %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :email, label: false %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>

  <!-- AGE -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Âge :</strong> <%= @user.age %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :age, label: false, as: :integer %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>

  <!-- GENDER -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Genre :</strong> <%= @user.gender %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :gender, label: false, collection: User::GENDERS, include_blank: false %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>

  <!-- HEIGHT -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Taille :</strong> <%= @user.height %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :height, label: false, as: :decimal %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>

  <!-- WEIGHT -->
  <div data-controller="toggle">
    <span data-toggle-target="text"><strong>Poids :</strong> <%= @user.weight %></span>

    <div data-toggle-target="form" class="hidden">
      <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
        <%= f.input :weight, label: false, as: :decimal %>
        <%= f.button :submit, "OK" %>
        <button type="button" data-action="toggle#toggle">Annuler</button>
      <% end %>
    </div>

    <button type="button" data-action="toggle#toggle">Modifier</button>
  </div>
</div>
