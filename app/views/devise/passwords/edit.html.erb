<div class="min-h-screen flex flex-col justify-center px-6 pb-12">

  <div class="mb-10">
    <h2 class="text-3xl font-bold">Nouveau<br>mot de passe</h2>
    <p class="text-white/40 text-sm mt-2">Choisis un nouveau mot de passe sécurisé.</p>
  </div>

  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= f.error_notification class: "text-error text-sm mb-4 block" %>
    <%= f.input :reset_password_token, as: :hidden %>

    <div>
      <label class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-2 block">Nouveau mot de passe</label>
      <%= f.input :password,
          label: false,
          wrapper: false,
          required: true,
          autofocus: true,
          hint: ("#{ @minimum_password_length } caractères minimum" if @minimum_password_length),
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>

    <div>
      <label class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-2 block">Confirmer le mot de passe</label>
      <%= f.input :password_confirmation,
          label: false,
          wrapper: false,
          required: true,
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>

    <div class="pt-2">
      <%= f.submit "Changer le mot de passe", class: "btn btn-primary btn-md w-full rounded-box" %>
    </div>

  <% end %>

  <div class="mt-8 text-center text-sm text-white/40">
    <p><%= link_to "Retour à la connexion", new_session_path(resource_name), class: "text-primary font-medium hover:underline" %></p>
  </div>

</div>
