<div class="min-h-screen flex flex-col justify-center px-6 pb-12">
  <div class="mb-10">
    <h2 class="font-bold">Créer un compte</h2>
    <p class="text-white/40 text-base mt-2">Rejoins la communauté DribbleCrew.</p>
  </div>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= f.error_notification class: "text-error text-sm mb-4 block" %>
    <div>
      <label class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-2 block">Pseudo</label>
      <%= f.input :username,
          label: false,
          wrapper: false,
          required: true,
          autofocus: true,
          input_html: { autocomplete: "username", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>
    <div>
      <label class="text-base font-semibold uppercase tracking-widest text-white/40 mb-2 block">Email</label>
      <%= f.input :email,
          label: false,
          wrapper: false,
          required: true,
          autofocus: true,
          input_html: { autocomplete: "email", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>
    <div>
      <label class="text-base font-semibold uppercase tracking-widest text-white/40 mb-2 block">Mot de passe</label>
      <%= f.input :password,
          label: false,
          wrapper: false,
          required: true,
          hint: ("#{ @minimum_password_length } caractères minimum" if @minimum_password_length),
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>
    <div>
      <label class="text-base font-semibold uppercase tracking-widest text-white/40 mb-2 block">Confirmer le mot de passe</label>
      <%= f.input :password_confirmation,
          label: false,
          wrapper: false,
          required: true,
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>
    <div class="pt-2">
      <%= f.submit "S'inscrire", class: "btn btn-primary btn-md w-full rounded-box" %>
    </div>
  <% end %>
  <div class="mt-8 text-center text-sm text-white/40">
    <p>Déjà un compte ? <%= link_to "Se connecter", new_session_path(resource_name), class: "text-primary font-medium hover:underline" %></p>
  </div>
</div>
