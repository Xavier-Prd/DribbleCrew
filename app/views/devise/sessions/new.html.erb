<div class="min-h-screen flex flex-col justify-center px-6 pb-12">

  <div class="mb-10">
    <h2 class="font-bold">Connexion</h2>
    <p class="text-white/40 text-base mt-2">Bon retour sur DribbleCrew.</p>
  </div>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>

    <div>
      <label class="text-base font-semibold uppercase tracking-widest text-white/40 mb-2 block">Email</label>
      <%= f.input :email,
          label: false,
          wrapper: false,
          required: false,
          autofocus: true,
          input_html: { autocomplete: "email", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>

    <div>
      <label class="text-base font-semibold uppercase tracking-widest text-white/40 mb-2 block">Mot de passe</label>
      <%= f.input :password,
          label: false,
          wrapper: false,
          required: false,
          input_html: { autocomplete: "current-password", class: "input input-bordered w-full bg-white/5 border-white/10 text-white focus:border-primary focus:outline-none" } %>
    </div>

    <% if devise_mapping.rememberable? %>
      <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" %>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Se connecter", class: "btn btn-primary btn-md w-full rounded-box" %>
    </div>

  <% end %>

  <div class="mt-8 space-y-3 text-center text-base text-white/40">
    <%- if devise_mapping.registerable? %>
      <p>Pas encore de compte ? <%= link_to "S'inscrire", new_registration_path(resource_name), class: "text-primary font-medium hover:underline" %></p>
    <% end %>
    <%- if devise_mapping.recoverable? %>
      <p><%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "hover:text-white transition-colors" %></p>
    <% end %>
  </div>

</div>
