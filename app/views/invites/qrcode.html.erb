<div class="min-h-screen pb-24 flex flex-col">
  <%# Header %>
  <div class="px-4 pt-6 pb-4 flex items-center">
    <%= link_to profile_path(current_user), class: "text-white/40 flex items-center gap-1 text-sm" do %>
      <i class="fa-solid fa-chevron-left"></i> Retour
    <% end %>
  </div>

  <div id="qr-ball" style="position:fixed;font-size:3rem;line-height:1;z-index:10;pointer-events:none;user-select:none;filter:drop-shadow(0 4px 20px rgba(250,108,0,0.5))">🏀</div>

  <div class="flex-1 flex flex-col items-center justify-center gap-8 px-6" style="position:relative;z-index:0">
    <div class="text-center">
      <h1 class="mb-1">Rejoins DribbleCrew</h1>
      <p class="text-white/40 text-sm">Scanne ce QR code pour accéder à l'app</p>
    </div>

    <%# Cadre QR code %>
    <div class="p-4 rounded-3xl bg-white shadow-[0_0_60px_rgba(250,108,0,0.25)]">
      <%= raw @qr_svg %>
    </div>

    <p class="text-white/20 text-xs tracking-widest uppercase">www.dribblecrew.site</p>
  </div>
</div>

<script>
  const ball = document.getElementById("qr-ball");
  const size = 48;
  let x = Math.random() * (window.innerWidth - size);
  let y = Math.random() * (window.innerHeight - size);
  let vx = (Math.random() * 3 + 2) * (Math.random() > 0.5 ? 1 : -1);
  let vy = (Math.random() * 3 + 2) * (Math.random() > 0.5 ? 1 : -1);
  let angle = 0;

  function animate() {
    x += vx;
    y += vy;
    angle += vx * 0.8;

    if (x <= 0)                        { x = 0;                        vx = Math.abs(vx); }
    if (x >= window.innerWidth - size) { x = window.innerWidth - size; vx = -Math.abs(vx); }
    if (y <= 0)                        { y = 0;                        vy = Math.abs(vy); }
    if (y >= window.innerHeight - size){ y = window.innerHeight - size; vy = -Math.abs(vy); }

    ball.style.left      = x + "px";
    ball.style.top       = y + "px";
    ball.style.transform = "rotate(" + angle + "deg)";
    requestAnimationFrame(animate);
  }

  animate();
</script>
