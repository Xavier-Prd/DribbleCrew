<div class="min-h-screen pb-24 flex flex-col">
  <%# Header %>
  <div class="px-4 pt-6 pb-4 flex items-center">
    <%= link_to profile_path(current_user), class: "text-white/40 flex items-center gap-1 text-sm" do %>
      <i class="fa-solid fa-chevron-left"></i> Retour
    <% end %>
  </div>

  <div class="flex-1 flex flex-col items-center justify-center gap-8 px-6">
    <div class="text-center">
      <h1 class="mb-1">Rejoins DribbleCrew</h1>
      <p class="text-white/40 text-sm">Scanne ce QR code pour accéder à l'app</p>
    </div>

    <%# Cadre QR code %>
    <div class="p-4 rounded-3xl bg-white shadow-[0_0_60px_rgba(250,108,0,0.25)]">
      <%= raw @qr_svg %>
    </div>

    <p class="text-white/20 text-xs tracking-widest uppercase">dribblecrew.site</p>
  </div>
</div>
