<% if user_signed_in? %>
  <nav class="fixed bottom-0 left-0 right-0 z-50 border-t border-white/10" style="background-color: var(--color-base-300);">
    <div class="flex items-center justify-around h-16">

      <% programs_active = request.path.start_with?('/programs') %>
      <%= link_to programs_path, class: "flex flex-col items-center gap-1 px-6 py-2", style: programs_active ? "color: var(--color-primary);" : "color: white;" do %>
        <i class="fa-solid fa-clipboard-list text-xl"></i>
        <span class="text-xs font-medium">Programs</span>
      <% end %>

      <% map_active = request.path == '/' %>
      <%= link_to root_path, class: "flex flex-col items-center gap-1 px-6 py-2", style: map_active ? "color: var(--color-primary);" : "color: white;" do %>
        <i class="fa-solid fa-location-dot text-xl"></i>
        <span class="text-xs font-medium">Map</span>
      <% end %>

      <% profile_active = request.path.start_with?('/profiles') %>
      <%= link_to profile_path(current_user), class: "flex flex-col items-center gap-1 px-6 py-2", style: profile_active ? "color: var(--color-primary);" : "color: white;" do %>
        <i class="fa-solid fa-user text-xl"></i>
        <span class="text-xs font-medium">Profile</span>
      <% end %>

    </div>
  </nav>
<% end %>
