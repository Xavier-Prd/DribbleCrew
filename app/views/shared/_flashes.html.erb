<div data-controller="flashes">

  <% if alert %>
    <div role="alert" class="flex alert alert-error fixed z-50">
      <span class="flex-1 text-center"><%= alert %></span>
      <button class="btn btn-circle btn-xs shrink-0" data-action="click->flashes#close">
        <i class="fa-solid fa-xmark text-error"></i>
      </button>
    </div>
  <% end %>

  <% if notice %>
    <div role="alert" class="flex alert alert-success fixed z-50">
      <span class="flex-1 text-center"><%= notice %></span>
      <button class="btn btn-circle btn-xs shrink-0" data-action="click->flashes#close">
        <i class="fa-solid fa-xmark text-success"></i>
      </button>
    </div>
  <% end %>

</div>
