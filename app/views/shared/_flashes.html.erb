<div data-controller="flashes">

  <% if alert %>
    <div role="alert" class="alert alert-error fixed z-50 bottom-20 right-10 z-50">
      <span><%= alert %></span>
      <button class="btn btn-circle btn-xs" data-action="click->flashes#close">
        <i class="fa-solid fa-xmark text-error"></i>
      </button>
    </div>
  <% end %>

  <% if notice %>
    <div role="alert" class="alert alert-success fixed z-50 bottom-20 right-10 z-50">
      <span><%= notice %></span>
      <button class="btn btn-circle btn-xs" data-action="click->flashes#close">
        <i class="fa-solid fa-xmark text-success"></i>
      </button>
    </div>
  <% end %>

</div>
