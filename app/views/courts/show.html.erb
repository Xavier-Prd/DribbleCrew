<div class="min-h-screen pb-12">
  <%# ===================== HERO ===================== %>
  <div class="relative h-56 overflow-hidden roundered-b-3xl">
    <% if @court.image.attached? %>
      <%= image_tag @court.image, class: "w-full h-full object-cover rounded-b-3xl" %>
    <% else %>
      <div class="w-full h-full bg-base-200 flex items-center justify-center">
        <i class="fa-solid fa-basketball text-4xl text-gray-600"></i>
      </div>
    <% end %>
    <div class="absolute inset-0 bg-gradient-to-t from-base-300 via-base-300/50 to-transparent rounded-b-3xl"></div>
    <%# Bouton retour %>
    <%= link_to root_path, class: "absolute top-4 left-4 text-white text-base flex items-center gap-1 z-10" do %>
      <i class="fa-solid fa-chevron-left text-base"></i> Retour
    <% end %>
    <%# Nom + adresse courte %>
    <div class="absolute bottom-4 left-4 right-4"
         data-controller="meet-filter"
         data-meet-filter-lat-value="<%= @court.lat %>"
         data-meet-filter-lng-value="<%= @court.long %>">
      <h2 class="text-2xl font-black text-white leading-tight"><%= @court.name %></h2>
      <div class="flex items-center justify-between mt-0.5">
        <p class="text-base text-gray-300 flex items-center gap-1">
          <i class="fa-solid fa-location-dot text-primary text-base"></i>
          <%= @court.address %>
        </p>
        <%# Lien vers Google Maps avec la distance calculée par le controller %>
        <%= link_to "https://www.google.com/maps/dir/?api=1&destination=#{@court.lat},#{@court.long}",
              target: "_blank", rel: "noopener",
              data: { "meet-filter-target": "distance" },
              class: "hidden items-center gap-1 bg-white/15 backdrop-blur-sm text-white text-sm font-semibold px-2.5 py-1 rounded-full" do %>
          <i class="fa-solid fa-location-arrow text-primary text-xs"></i>
          <span></span>
        <% end %>
      </div>
    </div>
    <%# Avatar du joueur connecté + ses points sur ce terrain %>
    <%= link_to profile_path(current_user), class: "absolute top-4 right-4 flex flex-col items-center gap-1" do %>
      <div class="relative w-11 h-11">
        <div class="w-full h-full rounded-full overflow-hidden">
          <% if current_user.profile_picture.attached? %>
            <%= image_tag current_user.profile_picture, class: "w-full h-full object-cover" %>
          <% else %>
            <div class="w-full h-full bg-base-200 flex items-center justify-center">
              <i class="fa-solid fa-user text-gray-400 text-xl"></i>
            </div>
          <% end %>
        </div>
        <%= image_tag "avatar_border_default.png", class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
      </div>
      <span class="badge badge-primary text-base font-bold px-2">
        <%= @user_points.round %> pts
      </span>
    <% end %>
  </div>
  <%# ===================== PODIUM ===================== %>
  <div class="px-6 mt-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-white">Classement</h2>
      <%= link_to "Voir plus", leaderboard_court_path(@court), class: "text-base text-gray-400 hover:text-white transition-colors" %>
    </div>
    <% top3 = @ranked_users.first(3) %>
    <% if top3.any? %>
      <div class="flex items-end justify-center gap-2 h-52">
        <%# 2ème place — gauche %>
        <div class="flex flex-col items-center flex-1 <%= top3[1] ? '' : 'invisible' %>">
          <% u2 = top3[1] %>
          <% if u2 %>
            <%= link_to profile_path(u2), class: "relative w-11 h-11 -mb-2 block" do %>
              <div class="w-full h-full rounded-full overflow-hidden shadow">
                <% if u2.profile_picture.attached? %>
                  <%= image_tag u2.profile_picture, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-base-100 flex items-center justify-center">
                    <i class="fa-solid fa-user text-gray-400 text-base"></i>
                  </div>
                <% end %>
              </div>
              <%= image_tag "avatar_border_second.png", class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
            <% end %>
            <div class="w-full rounded-t-xl flex flex-col items-center justify-end pb-3 h-24"
                 style="background: linear-gradient(to bottom, #f59e0b, #b45309);">
              <span class="text-white font-bold text-base"><%= @victory_counts[u2.id] || 0 %> pts</span>
            </div>
          <% end %>
        </div>
        <%# 1ère place — centre %>
        <div class="flex flex-col items-center flex-1 <%= top3[0] ? '' : 'invisible' %>">
          <% u1 = top3[0] %>
          <% if u1 %>
            <%= link_to profile_path(u1), class: "relative w-11 h-11 -mb-2 block" do %>
              <div class="w-full h-full rounded-full overflow-hidden shadow-lg">
                <% if u1.profile_picture.attached? %>
                  <%= image_tag u1.profile_picture, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-base-100 flex items-center justify-center">
                    <i class="fa-solid fa-user text-gray-400 text-xl"></i>
                  </div>
                <% end %>
              </div>
              <%= image_tag "avatar_border_king.png", class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
            <% end %>
            <div class="w-full rounded-t-xl flex flex-col items-center justify-end pb-3 h-36"
                 style="background: linear-gradient(to bottom, #fbbf24, #d97706);">
              <span class="text-white font-bold text-base"><%= @victory_counts[u1.id] || 0 %> pts</span>
            </div>
          <% end %>
        </div>
        <%# 3ème place — droite %>
        <div class="flex flex-col items-center flex-1 <%= top3[2] ? '' : 'invisible' %>">
          <% u3 = top3[2] %>
          <% if u3 %>
            <%= link_to profile_path(u3), class: "relative w-11 h-11 -mb-2 block" do %>
              <div class="w-full h-full rounded-full overflow-hidden shadow">
                <% if u3.profile_picture.attached? %>
                  <%= image_tag u3.profile_picture, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-base-100 flex items-center justify-center">
                    <i class="fa-solid fa-user text-gray-400 text-base"></i>
                  </div>
                <% end %>
              </div>
              <%= image_tag "avatar_border_third.png", class: "absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[100px] h-[100px] max-w-none pointer-events-none", alt: "" %>
            <% end %>
            <div class="w-full rounded-t-xl flex flex-col items-center justify-end pb-3 h-20"
                 style="background: linear-gradient(to bottom, #f97316, #c2410c);">
              <span class="text-white font-bold text-base"><%= @victory_counts[u3.id] || 0 %> pts</span>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-gray-400 text-center py-6 text-base">Aucun classement disponible</p>
    <% end %>
  </div>
  <%# ===================== RENCONTRES À VENIR ===================== %>
  <div class="bg-base-200 px-6 pt-6 pb-12 rounded-t-3xl">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-bold text-white">Rencontres à venir</h2>
      <%= link_to new_match_path(court_id: @court.id), class: "btn btn-primary btn-sm rounded-xl" do %>
        <i class="fa-solid fa-plus text-xs"></i> Créer un match
      <% end %>
    </div>
    <% if @upcoming_meets.any? %>
      <div class="flex flex-col gap-4">
        <% @upcoming_meets.each do |meet| %>
          <% if meet.meetable_type == "Match" %>
            <% match = meet.meetable %>
            <% cancelled = match.cancelled? %>
            <%= link_to meet_path(meet), class: "w-full rounded-2xl border overflow-hidden flex flex-col active:scale-[0.98] transition-transform", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.4);" do %>
              <% if cancelled %>
                <div class="h-1 w-full" style="background:linear-gradient(90deg,#ef4444,#ef444488);"></div>
              <% end %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <% if cancelled %>
                      <i class="fa-solid fa-ban text-[10px] text-red-400/80"></i>
                      <span class="text-xs font-black uppercase tracking-widest text-red-400/80">Match annulé</span>
                    <% else %>
                      <i class="fa-solid fa-trophy text-[10px]" style="color:#fbbf24;"></i>
                      <span class="text-xs font-black uppercase tracking-widest" style="color:var(--color-primary);">Match à venir</span>
                    <% end %>
                  </div>
                </div>
                <div class="flex items-center justify-center gap-2 py-3 px-3 rounded-2xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.blue_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Bleu</span>
                  </div>
                  <%= image_tag "vs.png", class: "w-12 h-12 object-contain mb-5" %>
                  <div class="flex flex-col items-center gap-1.5">
                    <span class="text-3xl font-black tabular-nums leading-none text-white/90 mb-3"><%= match.red_team.number_player %></span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/20">Rouge</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 truncate min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <%= link_to meet_path(meet), class: "w-full rounded-2xl border overflow-hidden flex flex-col active:scale-[0.98] transition-transform", style: "background:rgba(15,23,42,0.85); border-color:rgba(255,255,255,0.08);box-shadow:0 4px 24px rgba(0,0,0,0.4);" do %>
              <div class="px-4 pt-3 pb-4 flex flex-col gap-3 flex-1">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <i class="fa-solid fa-dumbbell text-[10px] text-purple-400/80"></i>
                    <span class="text-xs font-black uppercase tracking-widest text-purple-400/80">Entraînement</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <span class="text-base font-extrabold text-white leading-snug line-clamp-2"><%= meet.meetable.title %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-solid fa-signal text-[12px]"></i> Niveau : <%= meet.meetable.level %></span>
                  <span class="text-[14px] text-white/60 inline-flex items-center gap-1.5"><i class="fa-regular fa-clock text-[12px]"></i> Temps de la séance : <%= meet.duration %> min</span>
                </div>
                <div class="flex items-center justify-between pt-2 border-t border-white/8 mt-auto">
                  <div class="flex items-center gap-1 text-[14px] text-white/60 min-w-0">
                    <i class="fa-solid fa-location-dot text-[12px]"></i>
                    <span class="truncate"><%= meet.court.name %></span>
                  </div>
                  <span class="text-[14px] font-normal text-white shrink-0 ml-2"><%= meet.date.strftime("%-d %b · %H:%M") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-400 text-center py-6 text-base">Aucune rencontre à venir</p>
    <% end %>
  </div>
</div>
