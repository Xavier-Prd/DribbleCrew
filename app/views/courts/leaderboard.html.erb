<div class="min-h-screen bg-base-300 pb-24">

  <%# HEADER %>
  <div class="px-4 pt-6 pb-4 flex items-center justify-between">
    <%= link_to court_path(@court), class: "text-white text-sm flex items-center gap-1" do %>
      <i class="fa-solid fa-chevron-left text-xs"></i> Retour
    <% end %>
    <h1 class="text-lg font-bold text-white">Classement</h1>
    <div class="w-14"></div>
  </div>

  <%# Court name %>
  <div class="px-4 mb-4">
    <p class="text-gray-400 text-sm"><%= @court.name %></p>
  </div>

  <div class="px-4 flex flex-col gap-2">
    <% if @ranked_users.any? %>
      <% @ranked_users.each_with_index do |user, index| %>
        <div class="bg-base-200 rounded-2xl p-3 flex items-center gap-3">

          <span class="text-base font-black w-7 text-center shrink-0
            <%= index == 0 ? 'text-yellow-400' : index == 1 ? 'text-gray-300' : index == 2 ? 'text-orange-400' : 'text-gray-500' %>">
            <%= index + 1 %>
          </span>

          <div class="w-10 h-10 rounded-full overflow-hidden shrink-0">
            <% if user.profile_picture.attached? %>
              <%= image_tag user.profile_picture, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full bg-base-300 flex items-center justify-center">
                <i class="fa-solid fa-user text-gray-500 text-sm"></i>
              </div>
            <% end %>
          </div>

          <span class="text-white font-semibold flex-1 truncate"><%= user.username %></span>

          <span class="badge badge-warning font-bold text-xs shrink-0">
            <%= @victory_counts[user.id] || 0 %> pts
          </span>

        </div>
      <% end %>
    <% else %>
      <p class="text-gray-400 text-center py-6 text-sm">Aucun joueur classé sur ce terrain</p>
    <% end %>
  </div>

</div>
